# ===== Hugging Face =====
# Required to download gated models (Qwen3, etc.)
HF_TOKEN=your_huggingface_token_here

# ===== Weights & Biases (optional) =====
# Set to track training metrics
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=text2sql-slm-optimization
WANDB_DISABLED=true

# ===== Paths =====
# Override default data/model directories if needed
DATA_DIR=./data
CHECKPOINT_DIR=./checkpoints
RESULTS_DIR=./results
